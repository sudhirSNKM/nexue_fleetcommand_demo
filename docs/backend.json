
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user (Passenger, Driver, or Admin) in the ride-hailing system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Passenger", "Driver", "Admin", "Super Admin"] },
        "status": { "type": "string", "description": "Online/Offline status for drivers." },
        "vehicleDetails": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "model": { "type": "string" },
            "plate": { "type": "string" }
          }
        },
        "walletBalance": { "type": "number" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Ride": {
      "title": "Ride",
      "type": "object",
      "description": "Represents a single ride journey between a passenger and a driver.",
      "properties": {
        "id": { "type": "string" },
        "passengerId": { "type": "string" },
        "driverId": { "type": "string" },
        "pickup": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "dropoff": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "status": { "type": "string", "enum": ["Requested", "Accepted", "Arrived", "InProgress", "Completed", "Cancelled", "Paid"] },
        "fare": { "type": "number" },
        "vehicleType": { "type": "string", "enum": ["Bike", "Auto", "Cab"] },
        "distance": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "passengerId", "status", "pickup", "dropoff", "fare", "vehicleType"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "rideId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "DriverDailyStats": {
      "title": "DriverDailyStats",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "date": { "type": "string" },
        "earnings": { "type": "number" },
        "rideCount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "Global user profiles." }
      },
      {
        "path": "/rides/{rideId}",
        "definition": { "entityName": "Ride", "schema": { "$ref": "#/backend/entities/Ride" }, "description": "Ride transactions and history." }
      },
      {
        "path": "/rides/{rideId}/messages/{messageId}",
        "definition": { "entityName": "ChatMessage", "schema": { "$ref": "#/backend/entities/ChatMessage" }, "description": "In-ride messages." }
      },
      {
        "path": "/driverStats/{statId}",
        "definition": { "entityName": "DriverDailyStats", "schema": { "$ref": "#/backend/entities/DriverDailyStats" }, "description": "Aggregated daily earnings." }
      }
    ]
  }
}
