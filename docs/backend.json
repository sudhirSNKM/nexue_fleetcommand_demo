
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Core identity for all platform roles.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["SuperAdmin", "Admin", "Driver", "Passenger"] },
        "walletBalance": { "type": "number" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "role", "createdAt"]
    },
    "Ride": {
      "title": "Ride",
      "type": "object",
      "description": "Unified transport request (Passenger, Parcel, or Logistics).",
      "properties": {
        "id": { "type": "string" },
        "passengerId": { "type": "string" },
        "driverId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["Ride", "Parcel", "Logistics"] },
        "vehicleType": { "type": "string" },
        "pickup": { "type": "object", "properties": { "address": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "dropoff": { "type": "object", "properties": { "address": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "fare": { "type": "number" },
        "status": { "type": "string", "enum": ["Requested", "Accepted", "Arrived", "InProgress", "Completed", "Cancelled", "Paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "passengerId", "serviceType", "vehicleType", "pickup", "dropoff", "fare", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/userProfiles/{userId}", "definition": { "entityName": "User", "description": "Global user profiles." } },
      { "path": "/rides/{rideId}", "definition": { "entityName": "Ride", "description": "Active and historical ride data." } },
      { "path": "/driverStats/{statsId}", "definition": { "entityName": "DriverStats", "description": "Daily earnings telemetry." } },
      { "path": "/driverLocations/{driverId}", "definition": { "entityName": "Location", "description": "Real-time tracking coordinates." } }
    ]
  }
}
