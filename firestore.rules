
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getRole() {
      return hasProfile() ? getProfile().data.role : "passenger";
    }

    function isAdmin() {
      return signedIn() && (getRole() == "admin" || getRole() == "super-admin");
    }

    // USER PROFILES
    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // DRIVER SHIFTS - Permissive Debug Rule
    match /driverShifts/{shiftId} {
      allow read, write: if request.auth != null;
    }

    // PROFILE UPDATE REQUESTS - Permissive Debug Rule
    match /profileUpdateRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if signedIn();
    }

    // DRIVER STATS
    match /driverStats/{statsId} {
      allow read: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
      allow write: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
    }

  }
}
