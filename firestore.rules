
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Efficient role checks using specialized marker collections
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid))
      ); 
    }

    match /userProfiles/{userId} {
      // Allow user to read/write their own profile, or admins to oversee them
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /rides/{rideId} {
      // Allow read/list if the user is a participant, an admin, or discovering new requests
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.driverId ||
        resource.data.status == 'Requested'
      );

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.driverId ||
        (resource.data.status == 'Requested' && request.resource.data.status == 'Accepted')
      );

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }

    // Role markers for security rules
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /trips/{tripId} {
      allow read, write: if isSignedIn();
    }
    
    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }
  }
}
