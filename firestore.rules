
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isSuperAdmin();
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isStaff();
      allow delete: if isStaff();
    }

    match /roles_super_admin/{adminId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(adminId); // Demo: Allow self-assignment for demo purposes
      allow update, delete: if isSuperAdmin();
    }
    match /roles_admin/{adminId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(adminId); // Demo: Allow self-assignment for demo purposes
      allow update, delete: if isSuperAdmin();
    }

    match /vehicles/{vehicleId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isStaff();
      allow update: if isStaff() || isExistingOwner(resource.data.driverId);
    }

    match /trips/{tripId} {
      allow get, list: if isStaff() || isOwner(resource.data.driverId);
      allow create: if isStaff();
      allow update: if isStaff() || (isExistingOwner(resource.data.driverId) && request.resource.data.driverId == resource.data.driverId);
      allow delete: if isStaff();
    }

    match /driverShifts/{shiftId} {
      allow get, list: if isStaff() || isOwner(resource.data.driverId);
      allow create: if isOwner(request.resource.data.driverId);
      allow update: if isStaff() || (isExistingOwner(resource.data.driverId) && request.resource.data.driverId == resource.data.driverId);
      allow delete: if isStaff();

      match /driverBreaks/{breakId} {
        allow get, list: if isStaff() || isOwner(get(/databases/$(database)/documents/driverShifts/$(shiftId)).data.driverId);
        allow create, update: if isOwner(get(/databases/$(database)/documents/driverShifts/$(shiftId)).data.driverId);
        allow delete: if isStaff();
      }
    }

    match /fuelLogs/{logId} {
      allow get, list: if isStaff() || isOwner(resource.data.driverId);
      allow create: if isOwner(request.resource.data.driverId);
      allow update: if isStaff() || (isExistingOwner(resource.data.driverId) && request.resource.data.approvalStatus == resource.data.approvalStatus);
      allow delete: if isStaff();
    }
    match /expenseLogs/{logId} {
      allow get, list: if isStaff() || isOwner(resource.data.driverId);
      allow create: if isOwner(request.resource.data.driverId);
      allow update: if isStaff() || (isExistingOwner(resource.data.driverId) && request.resource.data.approvalStatus == resource.data.approvalStatus);
      allow delete: if isStaff();
    }

    match /maintenanceRecords/{recordId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /documents/{documentId} {
      allow get, list: if isStaff() || isOwner(resource.data.uploadedBy) || isOwner(resource.data.associatedEntityId);
      allow create: if isStaff() || isOwner(request.resource.data.uploadedBy);
      allow update: if isStaff() || isExistingOwner(resource.data.uploadedBy);
      allow delete: if isStaff();
    }

    match /zones/{zoneId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /systemSettings/{settingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow get, list: if isStaff();
      allow create, update, delete: if false; 
    }
  }
}
