rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- AUTH HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid))
      );
    }

    // --- USER PROFILES ---
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- ROLE MARKERS ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- RIDES ---
    match /rides/{rideId} {
      // Simplified security rule: Admin, Passenger, Driver, or Requested status
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.driverId ||
        resource.data.status == 'Requested'
      );

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.driverId ||
        resource.data.status == 'Requested'
      );

      allow delete: if isAdmin();

      // Nested chat messages for the ride
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- DRIVER TELEMETRY & STATS ---
    match /driver_locations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == driverId;
    }

    match /driverStats/{statId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.driverId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || resource.data.driverId == request.auth.uid);
    }

    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn() && (isAdmin() || resource.data.driverId == request.auth.uid);
    }

    // --- TRIPS (Logistics) ---
    match /trips/{tripId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.driverId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || resource.data.driverId == request.auth.uid);
    }

    // --- LOGS ---
    match /fuelLogs/{logId} { allow read, write: if isSignedIn(); }
    match /expenseLogs/{logId} { allow read, write: if isSignedIn(); }
  }
}