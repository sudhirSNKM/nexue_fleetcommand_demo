rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function role() {
      return getProfile().data.role;
    }

    function isSuperAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && role() == "super-admin";
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && (role() == "admin" || role() == "super-admin");
    }

    // USER PROFILES
    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // DRIVER SHIFTS
    match /driverShifts/{shiftId} {
      // DEBUG: Temporarily allow all authenticated users to read/write shifts
      // This is to unblock the 'list' error while validating roles
      allow read, write: if request.auth != null;
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if signedIn();
    }

  }
}