
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getRole() {
      // Safely fetch role, defaulting to passenger if profile missing
      return hasProfile() ? getProfile().data.role : "passenger";
    }

    function isSuperAdmin() {
      return signedIn() && getRole() == "super-admin";
    }

    function isAdmin() {
      // Match both admin and super-admin for hierarchical access
      return signedIn() && (getRole() == "admin" || getRole() == "super-admin");
    }

    // USER PROFILES
    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // DRIVER SHIFTS (TEMPORARY PERMISSIVE RULE FOR DEBUGGING)
    match /driverShifts/{shiftId} {
      allow read, write: if signedIn();
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if signedIn();
    }

    // DRIVER STATS
    match /driverStats/{statsId} {
      // statsId is structured as {driverId}_{date}
      allow read: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
      allow write: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
    }

  }
}
