rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getRole() {
      return hasProfile() ? getProfile().data.role : "passenger";
    }

    function isSuperAdmin() {
      return signedIn() && getRole() == "super-admin";
    }

    function isAdmin() {
      return signedIn() && (getRole() == "admin" || getRole() == "super-admin");
    }

    // USER PROFILES
    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // DRIVER SHIFTS
    match /driverShifts/{shiftId} {
      // Admins and Super Admins can read all shifts for tactical auditing (including list queries)
      allow read: if isAdmin();
      
      // Drivers can read only their own shifts (requires filtered query where driverId == auth.uid)
      allow read: if signedIn() && 
                  resource.data.driverId == request.auth.uid;

      // Admins manage the fleet's shifts globally
      allow create, update, delete: if isAdmin();

      // Drivers can create and update their own shift status
      allow create: if signedIn() && request.resource.data.driverId == request.auth.uid;
      allow update: if signedIn() && resource.data.driverId == request.auth.uid;
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if signedIn();
    }

    // DRIVER STATS
    match /driverStats/{statsId} {
      // statsId is structured as {driverId}_{date}
      allow read: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
      allow write: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
    }

  }
}