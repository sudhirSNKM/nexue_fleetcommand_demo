rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Temporarily allow all authenticated users to read/write core collections for debugging
    match /userProfiles/{userId} {
      allow read, write: if isSignedIn();
    }

    match /rides/{rideId} {
      allow read, write: if isSignedIn();
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }

    match /driverLocations/{driverId} {
      allow read, write: if isSignedIn();
    }

    // Role markers
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
    }

    // Catch-all permissive rule for authenticated users
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}