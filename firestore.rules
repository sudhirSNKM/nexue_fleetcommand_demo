rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Efficient role checks using specialized marker collections
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid))
      ); 
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /rides/{rideId} {
      // TEMPORARY: Allow all reads and writes for debugging
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == driverId;
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }
    
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }
    
    match /trips/{tripId} {
      allow read, write: if isSignedIn();
    }
    
    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }
  }
}