
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function hasRole(role) { return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == role; }
    function isAdmin() { return hasRole('Admin') || hasRole('Super Admin'); }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /rides/{rideId} {
      allow list: if isSignedIn() && (isAdmin() || request.query.where('passengerId', '==', request.auth.uid) || request.query.where('driverId', '==', request.auth.uid) || request.query.where('status', '==', 'Requested'));
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }
  }
}
