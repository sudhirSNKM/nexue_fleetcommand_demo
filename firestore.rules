
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      // Safer retrieval of user role from profile document
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      let role = getRole();
      return isSignedIn() && (role == "super-admin" || role == "Super Admin");
    }

    function isAdmin() {
      let role = getRole();
      return isSignedIn() && (role == "admin" || role == "super-admin" || role == "Admin" || role == "Super Admin");
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverShifts/{shiftId} {
      // Admins and Super Admins can read all shifts for tactical oversight
      allow read: if isAdmin();

      // Drivers can read only their own shifts (requires where("driverId", "==", auth.uid) filter)
      allow read: if isSignedIn() && resource.data.driverId == request.auth.uid;

      // Admins can manage all shift records
      allow write: if isAdmin();

      // Drivers can update their own active shifts (e.g., punching out)
      allow update: if isSignedIn() && resource.data.driverId == request.auth.uid;
      
      // Drivers can create their own shift entries
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.driverId == request.auth.uid);
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == driverId || isSuperAdmin());
    }

    match /auditLogs/{logId} {
      allow read: if isSignedIn() && isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /pricingRules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
