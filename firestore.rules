
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getRole() {
<<<<<<< HEAD
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      // Direct role validation from centralized identity document
      return signedIn() && (
        getRole() == "admin" || 
        getRole() == "super-admin" || 
        getRole() == "Admin" || 
        getRole() == "Super Admin"
      );
=======
      return hasProfile() ? getProfile().data.role : "passenger";
    }

    function isAdmin() {
      return signedIn() && (getRole() == "admin" || getRole() == "super-admin");
>>>>>>> 8d91e898ebbe712e1716a0f7cc35b84fa1454ac6
    }

    // USER PROFILES
    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    // DRIVER SHIFTS - Permissive Debug Rule for mission telemetry
    match /driverShifts/{shiftId} {
      allow read, write: if request.auth != null;
    }

    // PROFILE UPDATE REQUESTS - Permissive Debug Rule for administrative auditing
    match /profileUpdateRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if signedIn();
    }

    // DRIVER STATS
    match /driverStats/{statsId} {
      allow read: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
      allow write: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
    }

  }
}
