
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      // Safer retrieval of user profile document reference
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && getProfile().data.role == "Super Admin";
    }

    function isAdmin() {
      return isSignedIn() && (getProfile().data.role == "Admin" || getProfile().data.role == "Super Admin");
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverShifts/{shiftId} {
      // Admins and Super Admins can read all shifts (supports unrestricted list queries)
      allow read: if isAdmin();

      // Drivers can read only their own shifts (query must include driverId filter)
      allow read: if request.auth != null && request.auth.uid == resource.data.driverId;

      // Admins can manage all shift records
      allow write: if isAdmin();

      // Drivers can update their own active shifts (e.g., punching out)
      allow update: if request.auth != null && request.auth.uid == resource.data.driverId;
      
      // Drivers can create their own shift entries
      allow create: if request.auth != null && request.auth.uid == request.resource.data.driverId;
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == driverId || isSuperAdmin());
    }

    match /auditLogs/{logId} {
      allow read: if isSignedIn() && isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /pricingRules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
