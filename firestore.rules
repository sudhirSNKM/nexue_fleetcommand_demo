rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Efficient role checks using specialized marker collections
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid))
      ); 
    }

    match /userProfiles/{userId} {
      // Allow users to manage their own profile
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // Allow admins to manage all profiles
      allow read, write: if isAdmin();
    }

    match /rides/{rideId} {
      // Allow individual gets and filtered lists based on ownership or status
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.passengerId || 
        request.auth.uid == resource.data.driverId ||
        resource.data.status == "Requested" ||
        isAdmin()
      );
      
      // Allow creation for all signed-in units
      allow create: if isSignedIn();
      
      // Allow updates if owner, driver, or admin
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.passengerId || 
        request.auth.uid == resource.data.driverId ||
        isAdmin()
      );

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == driverId;
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
    
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    match /trips/{tripId} {
      allow read, write: if isSignedIn();
    }
    
    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }
  }
}