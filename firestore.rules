rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /userProfiles/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /rides/{rideId} {
      // Simple and safe ownership-based rules
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.driverId ||
        // Allow drivers to discover new requests
        (resource.data.status == "Requested")
      );

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.driverId ||
        // Allow a driver to accept a requested ride
        (resource.data.status == "Requested" && request.resource.data.status == "Accepted")
      );

      allow delete: if false;
    }

    // Secondary collections
    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }
    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }
    match /trips/{tripId} {
      allow read, write: if isSignedIn();
    }
    
    // Role markers
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
    }
  }
}