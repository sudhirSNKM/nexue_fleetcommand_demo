rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /userProfiles/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.active == true);
    }

    match /rides/{rideId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.passengerId || 
        request.auth.uid == resource.data.driverId ||
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.active == true
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.passengerId || 
        request.auth.uid == resource.data.driverId ||
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.active == true
      );
      
      allow delete: if false;
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }

    match /driverLocations/{driverId} {
      allow read, write: if isSignedIn();
    }

    // Role markers
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}