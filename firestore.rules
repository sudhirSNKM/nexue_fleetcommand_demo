rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY DEBUG RULES: Allowing all authenticated users full access
    // to confirm core functionality and resolve list permission errors.
    
    match /rides/{rideId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
      allow read, write: if request.auth != null;
    }

    // Allow other collections mentioned in backend.json for debugging
    match /driverStats/{statsId} {
      allow read, write: if request.auth != null;
    }

    match /driverLocations/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    match /driverShifts/{shiftId} {
      allow read, write: if request.auth != null;
    }
    
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }

    // Fallback for any other specialized role markers
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}