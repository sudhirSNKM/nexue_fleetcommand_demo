rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return signedIn() && role() == "super-admin";
    }

    function isAdmin() {
      return signedIn() && (role() == "admin" || role() == "super-admin");
    }

    // USER PROFILES
    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // DRIVER SHIFTS
    match /driverShifts/{shiftId} {

      // Admins can read the entire collection
      allow read: if isAdmin();

      // Drivers can read their own shifts
      allow read: if signedIn() &&
                  request.auth.uid == resource.data.driverId;

      // Admins manage shifts
      allow create, update, delete: if isAdmin();

      // Drivers update their own shift
      allow update: if signedIn() &&
                    request.auth.uid == resource.data.driverId;
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if signedIn();
    }

  }
}