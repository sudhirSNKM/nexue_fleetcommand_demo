rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- AUTH HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid))
      );
    }

    // --- USER PROFILES ---
    match /userProfiles/{userId} {
      // Allow any signed-in user to read profiles (needed for driver/passenger discovery)
      allow read: if isSignedIn();
      // Only the user themselves or an admin can modify a profile
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- ROLE MARKERS ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- RIDES ---
    match /rides/{rideId} {
      // allow read covers both get and list. 
      // For list, the query must be constrained to documents matching these rules.
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        resource.data.status == 'Requested'
      );

      // Any signed-in user can request a ride
      allow create: if isSignedIn();

      // Allow update if admin, or if user is passenger/driver, or if a driver is accepting a requested ride
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        resource.data.status == 'Requested'
      );

      allow delete: if isAdmin();

      // Nested chat messages for the ride
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- DRIVER TELEMETRY ---
    match /driver_locations/{driverId} {
      allow read: if isSignedIn();
      // Only the driver themselves can write their location
      allow write: if isSignedIn() && request.auth.uid == driverId;
    }

    // --- TRIPS (Duty/Logistics) ---
    match /trips/{tripId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        resource.data.driverId == request.auth.uid
      );
    }

    // --- ANALYTICS & SHIFTS ---
    match /driverStats/{statId} {
      allow read, write: if isSignedIn();
    }
    match /driverShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }

    // --- LOGS ---
    match /fuelLogs/{logId} { allow read, write: if isSignedIn(); }
    match /expenseLogs/{logId} { allow read, write: if isSignedIn(); }
  }
}