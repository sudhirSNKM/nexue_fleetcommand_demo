
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getRole() {
      return hasProfile() ? getProfile().data.role.toLower() : "passenger";
    }

    function isAdmin() {
      return signedIn() && (getRole() == "admin" || getRole() == "super-admin");
    }

    // USER PROFILES: Identity Registry
    // Reads are public to support email/phone resolution at login (before auth token exists).
    // Writes are restricted to the profile owner or an admin.
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    // DRIVER SHIFTS
    match /driverShifts/{shiftId} {
      allow read, write: if signedIn();
    }

    // PROFILE UPDATE REQUESTS
    match /profileUpdateRequests/{requestId} {
      allow read, write: if signedIn();
    }

    // DRIVER LOCATIONS
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == driverId;
    }

    // RIDES
    match /rides/{rideId} {
      allow read, write: if signedIn();
    }

    // PRICING RULES
    match /pricingRules/{ruleId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn();
    }

    // DRIVER STATS
    match /driverStats/{statsId} {
      allow read, write: if isAdmin() || (signedIn() && statsId.split('_')[0] == request.auth.uid);
    }

    // ALERTS
    match /alerts/{alertId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // SYSTEM SETTINGS
    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ADMIN CHATS
    match /adminChats/{chatId}/{document=**} {
      allow read, write: if isAdmin();
    }

    // FLEET ASSETS
    match /fleetAssets/{assetId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
