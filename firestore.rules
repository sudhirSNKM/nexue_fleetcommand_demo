rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && getProfile().role == "Super Admin";
    }

    function isAdmin() {
      return isSignedIn() && getProfile().role == "Admin";
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverShifts/{shiftId} {
      // Super Admin and Admin can read all shifts
      allow read: if isSignedIn() && (isSuperAdmin() || isAdmin());
      
      // Driver can read their own shift
      allow read: if isSignedIn() && resource.data.driverId == request.auth.uid;

      // Super Admin and Admin can manage (write) all shifts
      allow write: if isSignedIn() && (isSuperAdmin() || isAdmin());
      
      // Drivers can start/end their own shifts
      allow create: if isSignedIn() && request.resource.data.driverId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.driverId == request.auth.uid;
    }

    match /driverLocations/{driverId} {
      allow read, write: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
    }
    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}