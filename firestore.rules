
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      // Safer retrieval of user profile document
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && getProfile().data.role == "Super Admin";
    }

    function isAdmin() {
      return isSignedIn() && (getProfile().data.role == "Admin" || getProfile().data.role == "Super Admin");
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /driverStats/{statsId} {
      allow read, write: if isSignedIn();
    }

    match /driverShifts/{shiftId} {
      // Allow read if user is Admin OR if the driver is reading their own shift
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.driverId);
      
      // Allow creation if user is Admin OR if the driver is creating their own shift entry
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == request.resource.data.driverId);
      
      // Allow updates if user is Admin OR if the driver is updating their own shift (e.g., punching out)
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.driverId);
      
      // Only Admins can delete shift records
      allow delete: if isAdmin();
    }

    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == driverId || isSuperAdmin());
    }

    match /auditLogs/{logId} {
      allow read: if isSignedIn() && isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /pricingRules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
